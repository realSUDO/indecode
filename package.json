{
  "name": "trpc-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --ui=tui",
    "db:generate": "dotenv -- turbo db:generate",
    "db:migrate": "dotenv -- turbo db:migrate",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inngest/ai": "0.1.6",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4.1.18"
  },
  "pnpm": {
    "overrides": {
      "@inngest/ai": "0.1.6"
    }
  }
}
