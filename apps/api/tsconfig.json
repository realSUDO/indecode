{
  "extends": "@repo/typescript-config/node.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "Node",
    "module": "CommonJS",

    "declarationMap": false,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@repo/*": ["../../packages/*/src"]
    }
  },
  "include": ["src", "../../packages"],
  "ts-node": {
    "swc": true
  }
}
