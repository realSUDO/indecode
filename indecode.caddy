indecode.in, www.indecode.in {
    handle {
        reverse_proxy marketing:3000
    }
}

in.indecode.in {
    handle {
        reverse_proxy web:3000
    }
}

payment.indecode.in {
    handle {
        reverse_proxy payment:3000
    }
}

api.indecode.in {
    handle {
        reverse_proxy api:8080
    }
}

auth.indecode.in {
    handle {
        reverse_proxy auth:3000
    }
}

